# Copy to .env and edit for local/prod use.
POSTGRES_DB=boardgame
POSTGRES_USER=boardgame
POSTGRES_PASSWORD=boardgame
POSTGRES_PORT=5432
SERVER_PORT=8080

# iOS bundle id. Must match `aud` in Apple ID tokens.
APPLE_BUNDLE_ID=com.sanchitb.boardgame.app

# HMAC signing secret for session JWTs. Must be at least 32 bytes in prod.
BOARD_GAME_JWT_SECRET=dev-only-secret-change-me-at-least-32-bytes-please
BOARD_GAME_JWT_TTL_HOURS=720

SPRING_PROFILES_ACTIVE=default
